# Copy this file to .env and fill in the values before running docker compose.
# Never commit .env to version control.

# MySQL credentials — use strong, randomly generated passwords in production
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MYSQL_ROOT_PASSWORD=REPLACE_WITH_STRONG_ROOT_PASSWORD

# Public URL of your Ghost site (must match your domain in production)
GHOST_URL=http://localhost:2368
